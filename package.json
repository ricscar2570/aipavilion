{
  "name": "ai-pavilion",
  "version": "0.8.0",
  "private": true,
  "description": "Production-pilot staging, billing, trust and operations foundation for AI Pavilion.",
  "license": "MIT",
  "engines": {
    "node": "^20.19.0 || >=22.12.0",
    "npm": ">=10"
  },
  "scripts": {
    "clean": "rm -rf dist .aws-sam coverage",
    "dev": "vite --config vite.config.js",
    "build": "vite build --config vite.config.js",
    "preview": "vite preview --config vite.config.js",
    "config:check": "node scripts/validate-config.js",
    "test": "jest --runInBand",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage --runInBand",
    "lint": "eslint . --ext .js --max-warnings=0",
    "lint:fix": "eslint . --ext .js --fix",
    "format": "prettier --write \"**/*.{js,json,md,yml,yaml}\"",
    "format:check": "prettier --check \"**/*.{js,json,md,yml,yaml}\"",
    "check:syntax": "node scripts/check-syntax.js",
    "verify": "npm run format:check && npm run lint && npm run check:syntax && npm run check:contracts && npm run check:openapi && npm run check:bundles && npm run check:phase3 && npm run check:phase4 && npm run test:coverage -- --silent && npm run build",
    "sam:validate": "sam validate --lint --template-file template.yaml",
    "sam:build": "sam build --template-file template.yaml",
    "deploy:guided": "npm run verify && npm run sam:validate && sam deploy --guided",
    "deploy:ci": "npm run verify && npm run sam:validate && sam build --template-file template.yaml && sam deploy --no-confirm-changeset --no-fail-on-empty-changeset",
    "check:contracts": "node scripts/check-contracts.js",
    "check:bundles": "node scripts/check-lambda-bundles.js",
    "build:dev": "vite build --mode development --config vite.config.js",
    "test:integration": "jest tests/integration/dynamodb.deployed.test.js --runInBand",
    "test:smoke:deployed": "node scripts/dev/smoke-deployed.js",
    "test:e2e:deployed": "bash scripts/dev/run-browser-e2e.sh",
    "dev:deploy": "bash scripts/dev/deploy-dev.sh",
    "dev:destroy": "bash scripts/dev/destroy-dev.sh",
    "dev:seed": "node scripts/dev/seed-dev.js",
    "dev:users": "node scripts/dev/create-test-users.js",
    "check:openapi": "node scripts/check-openapi.js",
    "check:phase3": "node scripts/check-phase3-assets.js && bash -n scripts/dev/*.sh",
    "check:phase4": "node scripts/check-phase4-assets.js && bash -n scripts/pilot/*.sh",
    "pilot:generate": "node scripts/pilot/generate-pilot-backend.js",
    "pilot:check": "node scripts/pilot/generate-pilot-backend.js --check",
    "pilot:migrate": "node scripts/pilot/migrate.js apply",
    "pilot:migrate:plan": "node scripts/pilot/migrate.js plan",
    "pilot:migrate:verify": "node scripts/pilot/migrate.js verify",
    "pilot:deploy": "bash scripts/pilot/deploy-staging.sh",
    "pilot:synthetic": "node scripts/pilot/synthetic-check.js",
    "pilot:restore-drill": "bash scripts/pilot/restore-drill.sh"
  },
  "dependencies": {
    "@aws-sdk/client-cognito-identity-provider": "^3.600.0",
    "@aws-sdk/client-dynamodb": "^3.600.0",
    "@aws-sdk/client-secrets-manager": "^3.600.0",
    "@aws-sdk/client-sesv2": "^3.1086.0",
    "@aws-sdk/lib-dynamodb": "^3.600.0",
    "@aws-sdk/util-dynamodb": "^3.600.0",
    "amazon-cognito-identity-js": "^6.3.12",
    "aws-jwt-verify": "^4.0.1",
    "stripe": "^15.9.0"
  },
  "devDependencies": {
    "@babel/core": "^7.24.0",
    "@babel/preset-env": "^7.24.0",
    "autoprefixer": "^10.5.3",
    "babel-jest": "^29.7.0",
    "esbuild": "^0.28.1",
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "postcss": "^8.5.19",
    "prettier": "^3.2.5",
    "tailwindcss": "^3.4.19",
    "vite": "^8.1.4"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/tests/**/*.test.js",
      "**/__tests__/**/*.test.js"
    ],
    "collectCoverageFrom": [
      "backend/lambda/**/*.js",
      "!backend/lambda/common/**",
      "frontend/src/core/helpers.js",
      "frontend/src/core/validators.js",
      "frontend/src/core/templates.js",
      "frontend/src/checkout/cart.js",
      "frontend/src/core/api.js"
    ],
    "coverageThreshold": {
      "global": {
        "branches": 65,
        "functions": 70,
        "lines": 75,
        "statements": 75
      }
    }
  }
}
