# Local frontend configuration.
# A deployed development stack generates .env.development.local automatically.
# Copy this file to .env only when you need to configure the frontend manually.

NODE_ENV=development
AWS_REGION=eu-west-1

APP_NAME=AI Pavilion
APP_URL=http://127.0.0.1:3000
ALLOWED_ORIGIN=http://127.0.0.1:3000
SUPPORT_EMAIL=support@example.com

# Replace these three values with CloudFormation outputs from the disposable stack.
API_GATEWAY_URL=https://example.execute-api.eu-west-1.amazonaws.com/dev
COGNITO_USER_POOL_ID=eu-west-1_Example123
COGNITO_CLIENT_ID=exampleclient1234567890

# disabled: checkout unavailable
# simulated: full disposable-stack checkout without contacting Stripe
# stripe: Stripe test-mode checkout; STRIPE_PUBLISHABLE_KEY is then required
PAYMENT_MODE=disabled
STRIPE_PUBLISHABLE_KEY=

# Incomplete capabilities remain disabled until later product phases.
FEATURE_AR=false
FEATURE_360_TOURS=false
FEATURE_ANALYTICS=false
FEATURE_REVIEWS=false
FEATURE_WISHLIST=true
