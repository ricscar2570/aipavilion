{
  "name": "AI Pavilion - Virtual Gaming Expo",
  "short_name": "AI Pavilion",
  "description": "Enterprise virtual expo platform with AR, 360° tours, and real-time analytics",
  "start_url": "/",
  "scope": "/",
  "display": "standalone",
  "orientation": "portrait-primary",
  "theme_color": "#667eea",
  "background_color": "#ffffff",
  "categories": ["business", "productivity", "entertainment"],
  "lang": "en-US",
  "dir": "ltr",
  
  "icons": [
    {
      "src": "/icons/icon-72.png",
      "sizes": "72x72",
      "type": "image/png",
      "purpose": "any"
    },
    {
      "src": "/icons/icon-96.png",
      "sizes": "96x96",
      "type": "image/png",
      "purpose": "any"
    },
    {
      "src": "/icons/icon-128.png",
      "sizes": "128x128",
      "type": "image/png",
      "purpose": "any"
    },
    {
      "src": "/icons/icon-144.png",
      "sizes": "144x144",
      "type": "image/png",
      "purpose": "any"
    },
    {
      "src": "/icons/icon-152.png",
      "sizes": "152x152",
      "type": "image/png",
      "purpose": "any"
    },
    {
      "src": "/icons/icon-192.png",
      "sizes": "192x192",
      "type": "image/png",
      "purpose": "any maskable"
    },
    {
      "src": "/icons/icon-384.png",
      "sizes": "384x384",
      "type": "image/png",
      "purpose": "any"
    },
    {
      "src": "/icons/icon-512.png",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "any maskable"
    }
  ],
  
  "screenshots": [
    {
      "src": "/screenshots/desktop-home.png",
      "sizes": "1280x720",
      "type": "image/png",
      "form_factor": "wide",
      "label": "Homepage - Desktop View"
    },
    {
      "src": "/screenshots/mobile-stands.png",
      "sizes": "750x1334",
      "type": "image/png",
      "form_factor": "narrow",
      "label": "Browse Stands - Mobile View"
    },
    {
      "src": "/screenshots/desktop-ar.png",
      "sizes": "1280x720",
      "type": "image/png",
      "form_factor": "wide",
      "label": "AR Product View"
    },
    {
      "src": "/screenshots/mobile-360.png",
      "sizes": "750x1334",
      "type": "image/png",
      "form_factor": "narrow",
      "label": "360° Virtual Tour"
    }
  ],
  
  "shortcuts": [
    {
      "name": "Browse Stands",
      "short_name": "Stands",
      "description": "View all exhibition stands",
      "url": "/stands",
      "icons": [
        {
          "src": "/icons/shortcut-stands.png",
          "sizes": "96x96",
          "type": "image/png"
        }
      ]
    },
    {
      "name": "My Wishlist",
      "short_name": "Wishlist",
      "description": "View saved items",
      "url": "/wishlist",
      "icons": [
        {
          "src": "/icons/shortcut-wishlist.png",
          "sizes": "96x96",
          "type": "image/png"
        }
      ]
    },
    {
      "name": "Dashboard",
      "short_name": "Dashboard",
      "description": "Exhibitor dashboard",
      "url": "/dashboard",
      "icons": [
        {
          "src": "/icons/shortcut-dashboard.png",
          "sizes": "96x96",
          "type": "image/png"
        }
      ]
    }
  ],
  
  "share_target": {
    "action": "/share",
    "method": "POST",
    "enctype": "multipart/form-data",
    "params": {
      "title": "title",
      "text": "text",
      "url": "url",
      "files": [
        {
          "name": "media",
          "accept": ["image/*", "video/*"]
        }
      ]
    }
  },
  
  "related_applications": [
    {
      "platform": "webapp",
      "url": "https://aipavilion.com/manifest.json"
    }
  ],
  
  "prefer_related_applications": false,
  
  "protocol_handlers": [
    {
      "protocol": "web+aipavilion",
      "url": "/handler?url=%s"
    }
  ],
  
  "file_handlers": [
    {
      "action": "/open-3d-model",
      "accept": {
        "model/gltf-binary": [".glb"],
        "model/gltf+json": [".gltf"]
      }
    }
  ]
}
