{
  "name": "ai-pavilion",
  "version": "3.0.0",
  "description": "Virtual Gaming Expo Platform with AR and 360 Tours",
  "scripts": {
    "dev": "vite --config vite.config.js",
    "build": "node scripts/validate-config.js && vite build --config vite.config.js",
    "build:fast": "vite build --config vite.config.js",
    "preview": "vite preview --config vite.config.js",
    "validate-config": "node scripts/validate-config.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint . --ext .js",
    "lint:fix": "eslint . --ext .js --fix",
    "format": "prettier --write \"**/*.{js,json,md}\"",
    "deploy": "npm run validate-config && bash master-deploy.sh",
    "deploy:sam": "sam build && sam deploy --guided",
    "deploy:sam:ci": "sam build && sam deploy --no-confirm-changeset --no-fail-on-empty-changeset"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/yourusername/ai-pavilion.git"
  },
  "keywords": [
    "virtual-events",
    "gaming-expo",
    "ar",
    "360-tours",
    "aws",
    "serverless"
  ],
  "author": "AI Pavilion Team",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/yourusername/ai-pavilion/issues"
  },
  "homepage": "https://github.com/yourusername/ai-pavilion#readme",
  "dependencies": {
    "@aws-sdk/client-cognito-identity-provider": "^3.600.0",
    "@aws-sdk/client-dynamodb": "^3.600.0",
    "@aws-sdk/client-secrets-manager": "^3.600.0",
    "@aws-sdk/lib-dynamodb": "^3.600.0",
    "@aws-sdk/util-dynamodb": "^3.600.0",
    "amazon-cognito-identity-js": "^6.3.12",
    "aws-jwt-verify": "^4.0.1",
    "stripe": "^15.9.0"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/preset-env": "^7.29.0",
    "babel-jest": "^30.3.0",
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "jest-environment-node": "^29.7.0",
    "prettier": "^3.2.5",
    "vite": "^5.2.0"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/tests/**/*.test.js",
      "**/__tests__/**/*.test.js"
    ],
    "collectCoverageFrom": [
      "backend/lambda/**/*.js",
      "!backend/lambda/common/**",
      "frontend/src/core/helpers.js",
      "frontend/src/core/validators.js",
      "frontend/src/core/templates.js",
      "frontend/src/checkout/cart.js"
    ],
    "coverageThreshold": {
      "global": {
        "branches": 60,
        "functions": 70,
        "lines": 70
      }
    }
  }
}