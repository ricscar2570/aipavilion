# AWS Configuration
AWS_REGION=us-east-1
AWS_ACCOUNT_ID=your-account-id

# Stripe Configuration
STRIPE_SECRET_KEY=sk_test_your_secret_key
STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# Cognito Configuration
COGNITO_USER_POOL_ID=us-east-1_XXXXXXXXX
COGNITO_CLIENT_ID=your_client_id
COGNITO_REGION=us-east-1

# DynamoDB Configuration
DYNAMODB_TABLE_STANDS=ai-pavilion-stands
DYNAMODB_TABLE_PRODUCTS=ai-pavilion-products
DYNAMODB_TABLE_ORDERS=ai-pavilion-orders

# S3 Configuration
S3_BUCKET_FRONTEND=ai-pavilion-frontend-ACCOUNT_ID
S3_BUCKET_UPLOADS=ai-pavilion-uploads-ACCOUNT_ID

# CloudFront Configuration
CLOUDFRONT_DISTRIBUTION_ID=EXXXXXXXXXXXXX

# API Gateway Configuration
API_GATEWAY_URL=https://XXXXXXXXXX.execute-api.us-east-1.amazonaws.com/prod

# Application Configuration
APP_NAME=AI Pavilion
APP_URL=https://aipavilion.com
SUPPORT_EMAIL=support@aipavilion.com

# Monitoring
ALERT_TOPIC_ARN=arn:aws:sns:us-east-1:ACCOUNT_ID:aipavilion-alerts
LOG_LEVEL=info

# Environment
NODE_ENV=production
